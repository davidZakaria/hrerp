# Dependencies
node_modules/
hr-erp-frontend/node_modules/

# Production builds
hr-erp-frontend/build/
dist/

# Environment variables (CRITICAL - never commit these)
.env
.env.local
.env.production
.env.development
.env.*.local

# Super Admin Scripts (contain sensitive credentials)
createSuperAdmin.js
scripts/createSuperAdmin.js

# Backups (contain sensitive database dumps)
backups/
*.backup

# User uploads (contain sensitive user data)
uploads/
!uploads/.gitkeep
!uploads/medical-documents/.gitkeep
!uploads/resumes/.gitkeep
!uploads/attendance/.gitkeep
!uploads/avatars/.gitkeep

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pm2-error.log
pm2-out.log

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/

# nyc test coverage
.nyc_output

# Dependency directories
jspm_packages/

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
._*
